@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}
<h2>Reset Password</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">@Model.ErrorMessage</div>
}
@if (Model.Success)
{
    <div class="alert alert-success">Password reset successfully. <a href="/Account/Login">Login</a></div>
}
else
{
    <form method="post">
        <input type="hidden" asp-for="Token" />
        <input type="hidden" asp-for="Email" />
        <div>
            <label for="Password">New Password</label>
            <input asp-for="Password" type="password" id="Password" required />
        </div>
        <div>
            <label for="ConfirmPassword">Confirm Password</label>
            <input asp-for="ConfirmPassword" type="password" id="ConfirmPassword" required />
        </div>
        <button type="submit">Reset Password</button>
    </form>
}
