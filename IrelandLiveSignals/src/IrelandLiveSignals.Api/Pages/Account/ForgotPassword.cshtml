@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}
<h2>Forgot Password</h2>

@if (Model.EmailSent)
{
    <div class="alert alert-success">If that email address exists, a password reset link has been sent (or logged in development).</div>
}
else
{
    <form method="post">
        <div>
            <label for="Email">Email</label>
            <input asp-for="Email" type="email" id="Email" required />
        </div>
        <button type="submit">Send Reset Link</button>
    </form>
}
<p><a href="/Account/Login">Back to login</a></p>
