<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SignalEire</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#1a6b3c">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <link rel="apple-touch-icon" href="/icons/icon-192.png">
</head>
<body>
    <header>
        <h1>SignalEire <span class="subtitle">Ireland Live Grid</span></h1>
        <nav>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span>@(User.Identity.Name)</span>
                <a href="/Account/Manage">Account</a>
                <form method="post" action="/Account/Logout" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit">Logout</button>
                </form>
            }
            else
            {
                <a href="/Account/Login">Login</a>
                <a href="/Account/Register">Register</a>
            }
            <a href="/privacy">Privacy</a>
            <a href="/attribution">Attribution</a>
        </nav>
    </header>
    <main>
        @RenderBody()
    </main>
    <footer>
        <p>Data: EirGrid Smart Grid Dashboard &bull; Refreshes every 60s</p>
    </footer>

    <div id="pwa-install-banner" hidden style="background:#1a6b3c;color:#fff;padding:.75rem 1rem;display:flex;gap:1rem;align-items:center;justify-content:center">
        <span>Install Ireland Live Signals for quick access</span>
        <button id="pwa-install-btn" style="background:#fff;color:#1a6b3c;border:none;padding:.4rem .8rem;cursor:pointer;border-radius:4px">Install</button>
        <button onclick="this.closest('#pwa-install-banner').hidden=true" style="background:transparent;color:#fff;border:none;cursor:pointer">&#x2715;</button>
    </div>

    <div id="cookie-banner" hidden style="position:fixed;bottom:0;left:0;right:0;background:#222;color:#fff;padding:1rem;display:flex;gap:1rem;align-items:center;z-index:9999">
        <span>We use cookies for authentication and analytics. <a href="/privacy" style="color:#90caf9">Privacy policy</a></span>
        <button onclick="acceptCookies()" style="background:#1a6b3c;color:#fff;border:none;padding:.4rem .8rem;cursor:pointer;border-radius:4px">Accept</button>
        <button onclick="declineCookies()" style="background:transparent;color:#ccc;border:1px solid #ccc;padding:.4rem .8rem;cursor:pointer;border-radius:4px">Decline</button>
    </div>

    <script>
      if ('serviceWorker' in navigator) { navigator.serviceWorker.register('/sw.js'); }
    </script>
    <script src="/js/pwa-install.js"></script>
    <script src="/js/cookie-consent.js"></script>
</body>
</html>
