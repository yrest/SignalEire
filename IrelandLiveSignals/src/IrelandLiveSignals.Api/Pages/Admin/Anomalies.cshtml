@page
@model IrelandLiveSignals.Api.Pages.Admin.AnomaliesModel
@{
    ViewData["Title"] = "Signal Anomalies";
}

<h1>Signal Anomalies — Last 30 Days</h1>

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th>Date</th>
            <th>Module</th>
            <th>Type</th>
            <th>Region</th>
            <th>Route/Stop</th>
            <th>Observed</th>
            <th>Baseline</th>
            <th>Z-Score</th>
            <th>Explanation</th>
            <th>Detected</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var anomaly in Model.Anomalies)
        {
            var rowClass = anomaly.AnomalyType is "low_co2_day" ? "table-success" : "table-danger";
            <tr class="@rowClass">
                <td>@anomaly.Date.ToString("dd MMM")</td>
                <td>@anomaly.Module</td>
                <td>@anomaly.AnomalyType</td>
                <td>@anomaly.Region</td>
                <td>@(anomaly.RouteId ?? anomaly.StopId ?? "-")</td>
                <td>@anomaly.ObservedValue.ToString("F2")</td>
                <td>@anomaly.BaselineValue.ToString("F2")</td>
                <td>@anomaly.DeviationZScore.ToString("F1")σ</td>
                <td style="max-width:300px;font-size:0.85em">@anomaly.ExplanationText</td>
                <td>@anomaly.DetectedAtUtc.ToString("HH:mm dd MMM")</td>
            </tr>
        }
        @if (!Model.Anomalies.Any())
        {
            <tr><td colspan="10" class="text-muted">No anomalies detected in the last 30 days.</td></tr>
        }
    </tbody>
</table>
