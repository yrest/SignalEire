@page
@model IrelandLiveSignals.Api.Pages.Admin.IngestionModel
@{
    ViewData["Title"] = "Data Ingestion Stats";
}

<h1>Data Ingestion — Last 24 Hours</h1>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-header">Grid Readings</div>
            <div class="card-body">
                <h3 class="card-title">@Model.GridReadingsLast24h</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-header">Vehicle Observations</div>
            <div class="card-body">
                <h3 class="card-title">@Model.VehicleObservationsLast24h</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-header">Service Alerts</div>
            <div class="card-body">
                <h3 class="card-title">@Model.ServiceAlertsLast24h</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-header">Alert Deliveries</div>
            <div class="card-body">
                <h3 class="card-title">@Model.AlertDeliveriesLast24h</h3>
            </div>
        </div>
    </div>
</div>

<p class="text-muted">Stats as of @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm") UTC</p>
