<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:IrelandLiveSignals.MauiClient.ViewModels"
    xmlns:maps="clr-namespace:Maui.GoogleMaps;assembly=Maui.GoogleMaps"
    x:Class="IrelandLiveSignals.MauiClient.Views.MapPage"
    x:DataType="vm:MapViewModel"
    Title="Map">

    <Grid RowDefinitions="*,Auto">

        <maps:GoogleMap
            Grid.Row="0"
            x:Name="Map"
            InitialCameraUpdate="{maps:CameraUpdateFactory NewLatLngZoom={maps:LatLng 53.3, -8.0}, 7}"
            MyLocationEnabled="True"
            MyLocationButtonEnabled="True"
            Pins="{Binding StopPins}" />

        <Button
            Grid.Row="1"
            Text="Load Nearby Stops"
            Command="{Binding LoadStopsCommand}"
            Margin="16,8"
            HorizontalOptions="Fill" />

    </Grid>

</ContentPage>
