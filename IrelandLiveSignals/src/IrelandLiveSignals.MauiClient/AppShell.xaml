<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:IrelandLiveSignals.MauiClient.Views"
    x:Class="IrelandLiveSignals.MauiClient.AppShell"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Grid"
            Icon="icon_grid.svg"
            Route="Grid"
            ContentTemplate="{DataTemplate views:GridPage}" />

        <ShellContent
            Title="Transit"
            Icon="icon_transit.svg"
            Route="Transit"
            ContentTemplate="{DataTemplate views:TransitSearchPage}" />

        <ShellContent
            Title="Saved"
            Icon="icon_saved.svg"
            Route="Favourites"
            ContentTemplate="{DataTemplate views:FavouritesPage}" />

        <ShellContent
            Title="Account"
            Icon="icon_account.svg"
            Route="Account"
            ContentTemplate="{DataTemplate views:AccountPage}" />
    </TabBar>

</Shell>
